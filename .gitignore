# Browser profile (contains session cookies — never commit!)
profile/
*/profile/
.cookidoo-profile/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Playwright screenshots / debug
screenshots/
debug-*.png
*.tmp.html

# macOS
.DS_Store

# Webapp runtime state (SQLite DB + WAL, pinned-URL queue)
.state/
**/.state/

# Webapp build/deploy artifacts
webapp/node_modules/
webapp/.next/
webapp/out/
webapp/dist/

# Per-recipe extracted JSON + HF reference image — derived, can be regenerated
recipes/*/.extracted.json

# Local-only credentials never to be pushed
**/.credentials.json
**/credentials.json
*.env
.env.local
.env.production
