# Browser profile (contains session cookies — never commit!)
profile/
*/profile/
.cookidoo-profile/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Playwright screenshots / debug
screenshots/
debug-*.png
*.tmp.html

# macOS
.DS_Store

# Webapp runtime state (SQLite DB + WAL, pinned-URL queue)
.state/
**/.state/

# Webapp build/deploy artifacts
webapp/node_modules/
webapp/.next/
webapp/out/
webapp/dist/

# Per-recipe extracted JSON + HF reference image — derived, can be regenerated
recipes/*/.extracted.json

# Eingehende Original-Bilder (HF-Hero per WA, AI-restyle full-PNG, Notizen).
# Persistent für Re-Generation, aber nicht ins Repo — Source-Material kann
# urheberrechtlich geschützt sein (HF-Originale) und Files sind groß.
.received/

# Chat-bridge runtime logs (launchd writes here continuously)
scripts/chat_bridge/chat-bridge.log
scripts/chat_bridge/chat-bridge.stdout.log
scripts/chat_bridge/chat-bridge.stderr.log

# Local-only credentials never to be pushed
**/.credentials.json
**/credentials.json
*.env
.env.local
.env.production

# Peer-Briefe (können private Daten enthalten — nie committen)
.planning/inbox/
.planning/archive/
